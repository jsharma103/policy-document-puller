# Copy to .env and fill in. Carrier credentials are NEVER stored here — they're
# typed into the UI at runtime, used in-memory, and scrubbed. The only secrets
# on disk are the mobile-proxy creds below.

# Mobile proxy — required for State Farm from a datacenter/server IP (it
# fake-rejects datacenter IPs). Not needed when running locally on a residential
# IP. The SOAX_ prefix is historical: these are generic HTTP-proxy creds, so any
# US mobile provider works. The server builds http://{HOST}:{PORT} and passes
# USER/PASS as proxy auth; rotation/session params live inside USER.
#
# Examples (use one provider's set):
#   SOAX mobile:    HOST=proxy.soax.com  PORT=5000
#                   USER=package-XXXXXX-country-us-sessionid-XXXX-sessionlength-300
#   Decodo mobile:  HOST=us.decodo.com   PORT=10001
#                   USER=user-XXXXXXXX-sessionduration-60
SOAX_HOST=us.decodo.com
SOAX_PORT=10001
SOAX_USER=user-XXXXXXXX-sessionduration-60
SOAX_PASS=your-proxy-password

# Optional: force headless on/off regardless of a carrier's default ("0"|"1").
# HEADLESS=

# Optional: session inactivity TTL in seconds (default 600).
# SESSION_TTL=600
